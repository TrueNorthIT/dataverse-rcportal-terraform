# Copy to .env and fill in values. DO NOT commit .env to git.

# Dataverse Contact API
DATAVERSE_CONTACT_API_URL=https://api.dataverse-contact.tnapps.co.uk

# Pre-shared admin connection key. Must equal ADMIN_CONNECTION_KEY on the
# Contact API (Vercel). Sent by the provider as `Authorization: Bearer <key>`.
DATAVERSE_CONTACT_CONNECTION_KEY=<admin connection key>

# Scope to provision (optional — defaults to "rcportal")
SCOPE=rcportal
